{
  "name": "n8n-nodes-claude-code-bridge",
  "version": "1.0.0",
  "description": "Nodo n8n per usare Claude (via abbonamento Pro/Max, bridge Claude Code CLI) senza API key a consumo",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "author": "Nino Cordisco",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node copy-assets.js",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ClaudeCodeBridgeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ClaudeCodeBridge/ClaudeCodeBridge.node.js"
    ]
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "n8n-workflow": "^1.60.0"
  }
}
